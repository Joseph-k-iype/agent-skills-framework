# Skill evaluation framework — LLM judge configuration.
# Copy this file to .env and fill in the values for whichever provider you use.
# Nothing here is required: with no model configured, `skill evaluate` and the
# evaluation UI still run (structural checks only) with judge_status=skipped.

# "<langchain provider prefix>:<model name>" — passed to langchain's
# init_chat_model(), so ANY provider LangChain supports works, not just one.
# Examples:
#   SKILLS_EVAL_MODEL=anthropic:claude-haiku-4-5
#   SKILLS_EVAL_MODEL=openai:gpt-4o-mini
#   SKILLS_EVAL_MODEL=google_genai:gemini-2.0-flash
SKILLS_EVAL_MODEL=google_genai:gemini-2.0-flash

# Provide the API key matching whichever provider you set above.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
