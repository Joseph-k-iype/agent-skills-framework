# ─────────────────────────────────────────────────────────────
# EAKSO environment — copy to .env and fill in secrets
# ─────────────────────────────────────────────────────────────

# PostgreSQL (runs as a Docker image; backend connects from the host)
POSTGRES_USER=eakso
POSTGRES_PASSWORD=eakso
POSTGRES_DB=eakso
DATABASE_URL=postgresql+asyncpg://eakso:eakso@localhost:5432/eakso

# FalkorDB (runs as a Docker image; a Redis-protocol module, graph on db 0)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=eakso

# Redis is served by the FalkorDB container (Celery broker/result + cache)
REDIS_URL=redis://localhost:6379/3
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET=change-me-in-production-please
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# Development admin fallback (used when LDAP is disabled)
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin

# LDAP (disabled in dev — dev-admin path is used instead)
LDAP_ENABLED=false
LDAP_URI=ldap://localhost:389
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_BASE_DN=
LDAP_GROUP_BASE_DN=
# group CN -> role mapping (json)
LDAP_GROUP_ROLE_MAP={"eakso-admins":"admin","eakso-devs":"developer"}

# OpenRouter (LLM gateway — chat + embeddings)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
CHAT_MODEL=openai/gpt-oss-120b:free

# CORS (frontend origin)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
