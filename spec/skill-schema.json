{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://schemas.agent-skills.dev/skill.json",
  "title": "Agent Skill Manifest",
  "description": "Schema for an enterprise agent skill manifest with content-addressed identity",
  "type": "object",
  "required": ["name", "version", "runtime", "api_version", "entry"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^skill://sha256/[a-f0-9]{64}/[a-z][a-z0-9-]*@\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "description": "Content-addressed skill identifier (SPIFFE-inspired URI format: skill://sha256/<hash>/<name>@<version>)"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 2,
      "maxLength": 64,
      "description": "Unique skill identifier (kebab-case, 2-64 chars)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "description": "Semantic version of the skill (e.g. 1.0.0, 1.2.3-rc.1, 1.0.0+build.5)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of what the skill does"
    },
    "runtime": {
      "type": "string",
      "enum": ["python", "typescript"],
      "description": "Runtime the skill targets"
    },
    "api_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Version of the skill API contract this skill implements"
    },
    "entry": {
      "type": "string",
      "description": "Path to the entry point (relative to skill root)"
    },
    "triggers": {
      "type": "object",
      "properties": {
        "events": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Event names that trigger this skill"
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^/"
          },
          "description": "Slash-commands that invoke this skill"
        }
      },
      "description": "Event and command triggers"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Declared capabilities (for dependency resolution and graph queries)"
    },
    "config": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required configuration keys"
        },
        "schema": {
          "type": "object",
          "description": "JSON Schema for config validation"
        }
      },
      "description": "Configuration specification"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "pip": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Python pip dependencies"
        },
        "npm": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Node.js npm dependencies"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*@"
          },
          "description": "Other skills this skill depends on (name@version)"
        }
      },
      "description": "Runtime and inter-skill dependencies"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource", "actions"],
        "properties": {
          "resource": { "type": "string" },
          "actions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["read", "write", "create", "delete", "list", "execute"]
            }
          }
        }
      },
      "description": "Declared resource permissions the skill requires"
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "on_install": { "type": "string" },
        "on_uninstall": { "type": "string" },
        "on_upgrade": { "type": "string" }
      },
      "description": "Lifecycle hook scripts (relative to skill root)"
    }
  }
}
